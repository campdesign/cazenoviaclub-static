---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = "A private tennis and social club on the stunning shores of Cazenovia Lake." } = Astro.props;

const navLinks = [
  { label: "Welcome", href: "/" },
  {
    label: "Events",
    href: "/events/calendar/",
    children: [
      { label: "Calendar", href: "/events/calendar/" },
      { label: "Private Events", href: "/events/private-events/" },
      { label: "Youth Program", href: "/events/youth-program/" },
      { label: "Tennis", href: "/events/tennis/" },
    ],
  },
  {
    label: "About",
    href: "/about/staff/",
    children: [
      { label: "History", href: "/about/history/" },
      { label: "Staff", href: "/about/staff/" },
      { label: "Board of Governors", href: "/about/board-of-governors/" },
    ],
  },
  { label: "Reservations", href: "/reservations/" },
  { label: "Members", href: "/members/newsletter/", children: [
    { label: "Newsletter Sign-Up", href: "/members/newsletter/" },
  ]},
];

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Cazenovia Club</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet" />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body class="bg-[#FAF7F2]">

    <!-- Header -->
    <header class="bg-[#1B2A4A] sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">

        <a href="/" class="flex items-center gap-3 shrink-0">
          <img
            src="/images/cropped-Caz-CLub-logo_white.png"
            alt="Cazenovia Club"
            class="h-9 w-auto"
            onerror="this.style.display='none';this.nextElementSibling.style.display='block'"
          />
          <span class="text-white hidden" style="font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:300;letter-spacing:0.14em;">
            CAZENOVIA CLUB
          </span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-8">
          {navLinks.map((link) =>
            link.children ? (
              <div class="dropdown relative flex items-center">
                <a href={link.href} class={`nav-link text-white/80 hover:text-white ${currentPath.startsWith('/' + link.label.toLowerCase()) ? '!text-[#C9A96E]' : ''}`}>
                  {link.label}
                </a>
                <div class="dropdown-menu hidden absolute top-full left-0 bg-[#1B2A4A] border-t border-[#C9A96E]/30 min-w-[190px] shadow-2xl z-50 py-2">
                  {link.children.map((child) => (
                    <a
                      href={child.href}
                      class={`block px-5 py-3 nav-link text-white/70 hover:text-white hover:bg-white/5 whitespace-nowrap ${currentPath === child.href ? '!text-[#C9A96E]' : ''}`}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <a
                href={link.href}
                class={`nav-link text-white/80 hover:text-white ${currentPath === link.href ? '!text-[#C9A96E]' : ''}`}
              >
                {link.label}
              </a>
            )
          )}
        </nav>

        <button id="mobile-menu-btn" class="md:hidden text-white/70 hover:text-white p-1" aria-label="Toggle menu">
          <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div id="mobile-menu" class="hidden md:hidden bg-[#1B2A4A] border-t border-[#C9A96E]/20">
        {navLinks.map((link) => (
          <div class="border-b border-white/5">
            <a href={link.href} class="block px-6 py-3 nav-link text-white/80 hover:text-white">{link.label}</a>
            {link.children?.map((child) => (
              <a href={child.href} class="block px-10 py-2.5 nav-link text-white/50 hover:text-white/90">{child.label}</a>
            ))}
          </div>
        ))}
      </div>
    </header>

    <main><slot /></main>

    <!-- Footer -->
    <footer class="bg-[#1B2A4A] text-white mt-24">
      <div class="max-w-6xl mx-auto px-6 pt-16 pb-10 grid grid-cols-1 md:grid-cols-3 gap-12">

        <div>
          <img src="/images/cropped-Caz-CLub-logo_white.png" alt="Cazenovia Club" class="h-11 w-auto mb-6 opacity-80" onerror="this.style.display='none'" />
          <p style="font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:300;" class="text-white/50 leading-relaxed mb-6">
            A private tennis and social club on the shores of Cazenovia Lake.
          </p>
          <div style="font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:300;line-height:1.9;" class="text-white/40 space-y-1">
            <p>Cazenovia Club Corporation</p>
            <p>P.O. Box 412</p>
            <p>Cazenovia, NY 13035-0412</p>
            <p class="pt-2"><a href="tel:3156553131" class="hover:text-white/70 transition-colors">315.655.3131</a></p>
            <p><a href="mailto:info@cazenoviaclub.org" class="hover:text-white/70 transition-colors">info@cazenoviaclub.org</a></p>
          </div>
        </div>

        <div>
          <p class="label text-[#C9A96E] mb-6">Navigation</p>
          <ul class="space-y-3">
            {navLinks.map(link => (
              <li><a href={link.href} class="nav-link text-white/50 hover:text-white/90 transition-colors">{link.label}</a></li>
            ))}
          </ul>
        </div>

        <div>
          <p class="label text-[#C9A96E] mb-6">Inquiries</p>
          <p style="font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:300;" class="text-white/50 leading-relaxed mb-6">
            For membership or other inquiries:
          </p>

          <!-- Netlify form — submissions handled automatically on Netlify -->
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            id="footer-contact-form"
            class="space-y-3"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden"><input name="bot-field" /></p>

            <input
              type="text"
              name="name"
              placeholder="Your name"
              required
              class="w-full bg-white/8 border border-white/15 text-white/80 placeholder-white/30 px-4 py-2.5 text-sm focus:outline-none focus:border-[#C9A96E]/60 transition-colors"
              style="font-family:'Cormorant Garamond',serif;font-size:1rem;"
            />
            <input
              type="email"
              name="email"
              placeholder="Email address"
              required
              class="w-full bg-white/8 border border-white/15 text-white/80 placeholder-white/30 px-4 py-2.5 text-sm focus:outline-none focus:border-[#C9A96E]/60 transition-colors"
              style="font-family:'Cormorant Garamond',serif;font-size:1rem;"
            />
            <textarea
              name="message"
              placeholder="Your message"
              rows="3"
              required
              class="w-full bg-white/8 border border-white/15 text-white/80 placeholder-white/30 px-4 py-2.5 text-sm focus:outline-none focus:border-[#C9A96E]/60 transition-colors resize-none"
              style="font-family:'Cormorant Garamond',serif;font-size:1rem;"
            ></textarea>

            <button
              type="submit"
              class="label text-[#C9A96E] border border-[#C9A96E]/40 px-6 py-2.5 hover:bg-[#C9A96E]/10 transition-colors w-full tracking-widest"
              style="font-size:0.6rem;"
            >
              Send Inquiry
            </button>

            <!-- Success message (shown after submit via JS) -->
            <p id="form-success" class="hidden text-[#C9A96E] text-sm pt-1" style="font-family:'Cormorant Garamond',serif;">
              Thank you — we'll be in touch.
            </p>
          </form>
        </div>

      </div>
      <div class="border-t border-white/10 py-6 text-center">
        <p class="label text-white/25" style="font-size:0.6rem;">
          &copy; {new Date().getFullYear()} &nbsp;&middot;&nbsp; Cazenovia Club &nbsp;&middot;&nbsp; All Rights Reserved
        </p>
      </div>
    </footer>

    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", (user: any) => {
          if (!user) {
            window.netlifyIdentity.on("login", () => { document.location.href = "/admin/"; });
          }
        });
      }
      // Contact form — show success message on submit
      const contactForm = document.getElementById('footer-contact-form');
      contactForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target as HTMLFormElement;
        const data = new FormData(form);
        await fetch('/', { method: 'POST', body: data });
        form.reset();
        document.getElementById('form-success')?.classList.remove('hidden');
      });

      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const iconOpen = document.getElementById('icon-open');
      const iconClose = document.getElementById('icon-close');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
        iconOpen?.classList.toggle('hidden');
        iconClose?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
