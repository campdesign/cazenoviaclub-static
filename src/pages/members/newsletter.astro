---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Newsletter Sign-Up" description="Sign up for the Cazenovia Club member newsletter.">

  <!-- ══ HEADER ════════════════════════════════════════════════════ -->
  <div class="bg-[#1B2A4A] py-16 text-center">
    <p style="font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.2em;" class="text-[#C9A96E] uppercase mb-3">Members Only</p>
    <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,4vw,3rem);font-weight:300;" class="text-white">Newsletter Sign-Up</h1>
    <p style="font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:300;" class="text-white/50 mt-3 italic">Stay informed about Club events, news, and announcements</p>
  </div>


  <!-- ══ FORM ══════════════════════════════════════════════════════ -->
  <section class="max-w-xl mx-auto px-6 py-20">

    <div class="flex items-center gap-4 justify-center mb-12">
      <div class="h-px w-16 bg-[#C9A96E]"></div>
      <div class="w-1 h-1 rounded-full bg-[#C9A96E]"></div>
      <div class="h-px w-16 bg-[#C9A96E]"></div>
    </div>

    <!-- Mailchimp Form -->
    <link href="//cdn-images.mailchimp.com/embedcode/classic-061523.css" rel="stylesheet" type="text/css" />

    <style>
      /* ── Reset Mailchimp defaults ── */
      #mc_embed_signup { background: transparent !important; width: 100% !important; }
      #mc_embed_signup form { padding: 0 !important; }
      #mc_embed_signup h2 { display: none; }
      #mc_embed_signup .indicates-required { display: none; }

      /* ── Labels ── */
      #mc_embed_signup label {
        font-family: 'Montserrat', sans-serif !important;
        font-size: 0.6rem !important;
        letter-spacing: 0.18em !important;
        text-transform: uppercase !important;
        color: #C9A96E !important;
        margin-bottom: 0.5rem !important;
      }

      /* ── Inputs ── */
      #mc_embed_signup input[type="email"],
      #mc_embed_signup input[type="text"] {
        font-family: 'Cormorant Garamond', serif !important;
        font-size: 1.05rem !important;
        font-weight: 300 !important;
        color: #1B2A4A !important;
        background: #FAF7F2 !important;
        border: 1px solid rgba(201,169,110,0.35) !important;
        border-radius: 0 !important;
        width: 100% !important;
        padding: 0.75rem 1rem !important;
        box-shadow: none !important;
        outline: none !important;
        height: auto !important;
      }
      #mc_embed_signup input[type="email"]:focus,
      #mc_embed_signup input[type="text"]:focus {
        border-color: #C9A96E !important;
      }

      /* ── Field groups ── */
      #mc_embed_signup .mc-field-group {
        padding-bottom: 1.5rem !important;
        width: 100% !important;
      }

      /* ── Submit button ── */
      #mc_embed_signup .button,
      #mc_embed_signup input[type="submit"] {
        font-family: 'Montserrat', sans-serif !important;
        font-size: 0.65rem !important;
        letter-spacing: 0.2em !important;
        text-transform: uppercase !important;
        background-color: #1B2A4A !important;
        color: #FAF7F2 !important;
        border: none !important;
        border-radius: 0 !important;
        padding: 0.85rem 2.5rem !important;
        height: auto !important;
        cursor: pointer !important;
        transition: background-color 0.2s !important;
        width: auto !important;
      }
      #mc_embed_signup .button:hover,
      #mc_embed_signup input[type="submit"]:hover {
        background-color: #C9A96E !important;
      }

      /* ── Response messages ── */
      #mc_embed_signup #mce-success-response {
        font-family: 'Cormorant Garamond', serif !important;
        font-size: 1.05rem !important;
        color: #1B2A4A !important;
        padding: 1rem 0 !important;
      }
      #mc_embed_signup #mce-error-response {
        font-family: 'Cormorant Garamond', serif !important;
        font-size: 1rem !important;
        color: #8B2020 !important;
        padding: 1rem 0 !important;
      }

      /* ── Hide Mailchimp branding ── */
      #mc_embed_signup .optionalParent p { display: none !important; }
      #mc_embed_signup .clear.foot { display: flex; align-items: center; }
    </style>

    <div id="mc_embed_signup">
      <form
        action="https://Cazenoviaclub.us2.list-manage.com/subscribe/post?u=f6774201945240781000cffde&amp;id=5d1a5b5c54&amp;f_id=00f794e3f0"
        method="post"
        id="mc-embedded-subscribe-form"
        name="mc-embedded-subscribe-form"
        class="validate"
        target="_blank"
      >
        <div id="mc_embed_signup_scroll">

          <div class="mc-field-group">
            <label for="mce-EMAIL">Email Address <span class="asterisk">*</span></label>
            <input type="email" name="EMAIL" class="required email" id="mce-EMAIL" required value="" />
          </div>

          <div class="mc-field-group">
            <label for="mce-FNAME">First Name</label>
            <input type="text" name="FNAME" class="text" id="mce-FNAME" value="" />
          </div>

          <div class="mc-field-group">
            <label for="mce-LNAME">Last Name</label>
            <input type="text" name="LNAME" class="text" id="mce-LNAME" value="" />
          </div>

          <div id="mce-responses" class="clear foot">
            <div class="response" id="mce-error-response" style="display:none;"></div>
            <div class="response" id="mce-success-response" style="display:none;"></div>
          </div>

          <!-- Bot trap — do not remove -->
          <div aria-hidden="true" style="position:absolute;left:-5000px;">
            <input type="text" name="b_f6774201945240781000cffde_5d1a5b5c54" tabindex="-1" value="" />
          </div>

          <div class="optionalParent">
            <div class="clear foot">
              <input type="submit" name="subscribe" id="mc-embedded-subscribe" class="button" value="Subscribe" />
            </div>
          </div>

        </div>
      </form>
    </div>

    <script type="text/javascript" src="//s3.amazonaws.com/downloads.mailchimp.com/js/mc-validate.js" is:inline></script>
    <script type="text/javascript" is:inline>
      (function($) {
        window.fnames = new Array();
        window.ftypes = new Array();
        fnames[0]='EMAIL'; ftypes[0]='email';
        fnames[1]='FNAME'; ftypes[1]='text';
        fnames[2]='LNAME'; ftypes[2]='text';
      }(jQuery));
      var $mcj = jQuery.noConflict(true);
    </script>

  </section>

</Layout>
