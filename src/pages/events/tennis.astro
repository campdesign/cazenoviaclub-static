---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Tennis" description="Tennis instruction and programs at the Cazenovia Club with certified pro Dave Garzia.">

  <!-- ══ HEADER ════════════════════════════════════════════════════ -->
  <div class="relative h-[50vh] min-h-[340px] overflow-hidden flex items-end">
    <img
      src="/images/tennis.jpg"
      alt="Tennis at the Cazenovia Club"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#1B2A4A]/80 via-[#1B2A4A]/30 to-transparent"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6 pb-12 w-full">
      <p style="font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.2em;" class="text-[#C9A96E] uppercase mb-3">Cazenovia Club</p>
      <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(2.2rem,5vw,3.5rem);font-weight:300;" class="text-white">Tennis</h1>
    </div>
  </div>


  <!-- ══ INTRO ══════════════════════════════════════════════════════ -->
  <section class="max-w-3xl mx-auto px-6 py-20 text-center">
    <div class="flex items-center gap-4 justify-center mb-10">
      <div class="h-px w-16 bg-[#C9A96E]"></div>
      <div class="w-1 h-1 rounded-full bg-[#C9A96E]"></div>
      <div class="h-px w-16 bg-[#C9A96E]"></div>
    </div>
    <p style="font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-weight:300;line-height:1.9;" class="text-[#3D3835]/75 mb-6">
      The Cazenovia Club offers court facilities and professional instruction for players of all skill levels. We also offer pickleball, welcoming a new generation of players to the lakeside.
    </p>
    <p style="font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-weight:300;line-height:1.9;" class="text-[#3D3835]/75">
      Programming includes clinics, tournaments, social mixers, and private instruction — all tailored to help you improve your game in one of the most beautiful settings in Central New York.
    </p>
  </section>


  <!-- ══ PRO BIO ════════════════════════════════════════════════════ -->
  <section class="max-w-4xl mx-auto px-6 pb-20">
    <div class="border-t border-[#C9A96E]/20 pt-16 flex flex-col md:flex-row gap-12 items-start">
      <div class="shrink-0">
        <img
          src="/images/IMG_2904-769x1024.jpg"
          alt="Dave Garzia – Tennis Pro"
          class="w-52 h-64 object-cover shadow-md"
        />
      </div>
      <div>
        <p style="font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.2em;" class="text-[#C9A96E] uppercase mb-3">Tennis Professional</p>
        <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:300;" class="text-[#1B2A4A] mb-5">Dave Garzia</h2>
        <div class="w-8 h-px bg-[#C9A96E] mb-6"></div>
        <p style="font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:300;line-height:1.9;" class="text-[#3D3835]/75 mb-4">
          Dave brings 10 years of teaching experience and studied exercise science at OCC and SUNY Cortland. He holds multiple professional certifications including USPTA (2014), International Coaches Institute Level 2 (2020), NASM Performance Enhancing Specialist, and ISSA Personal Trainer.
        </p>
        <p style="font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:300;line-height:1.9;" class="text-[#3D3835]/75 mb-8">
          His comprehensive approach to training integrates both physical and mental conditioning, working with players of all skill levels to help them develop their full potential on the court.
        </p>
        <div class="flex flex-wrap gap-2">
          {["USPTA Certified", "Int'l Coaches Institute L2", "NASM Performance Specialist", "ISSA Personal Trainer"].map(cert => (
            <span style="font-family:'Montserrat',sans-serif;font-size:0.55rem;letter-spacing:0.1em;" class="border border-[#C9A96E]/40 text-[#1B2A4A]/60 uppercase px-3 py-1.5">{cert}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

</Layout>
