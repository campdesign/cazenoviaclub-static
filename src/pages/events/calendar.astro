---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Events Calendar" description="A calendar of events for the Cazenovia Club season.">

  <!-- ══ HEADER ════════════════════════════════════════════════════ -->
  <div class="bg-[#1B2A4A] py-16 text-center">
    <p style="font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.2em;" class="text-[#C9A96E] uppercase mb-3">Cazenovia Club</p>
    <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,4vw,3rem);font-weight:300;" class="text-white">Events Calendar</h1>
    <p style="font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:300;" class="text-white/50 mt-3 italic">A calendar of events for the season</p>
  </div>

  <section class="max-w-5xl mx-auto px-6 py-16">

    <!-- Styled Calendar Embed -->
    <iframe
      src="https://embed.styledcalendar.com/#fywZsJFO9hIAgttJkrw1"
      title="Styled Calendar"
      class="styled-calendar-container"
      style="width:100%;border:none;min-height:700px;"
      data-cy="calendar-embed-iframe"
    ></iframe>
    <script async type="module" src="https://embed.styledcalendar.com/assets/parent-window.js" is:inline></script>

    <p style="font-family:'Cormorant Garamond',serif;font-size:0.9rem;font-weight:300;" class="text-center text-[#3D3835]/40 mt-6 italic">
      Times shown in Eastern Time. Contact the club for more information about any event.
    </p>

  </section>

</Layout>
