---
import Layout from '../../layouts/Layout.astro';

const officers = [
  { title: "President",      name: "Lisa Hodgkins" },
  { title: "Vice President", name: "James McDonough" },
  { title: "Secretary",      name: "John P. Langan" },
  { title: "Treasurer",      name: "Michael Woltman" },
];

const governors = [
  "Charles Andrews III",
  "Robert Connor",
  "Paul J. Curtin, Jr.",
  "Ainslie Ellis",
  "Kate Franz",
  "Casey Frazee",
  "Lisa Hodgkins",
  "John P. Langan",
  "Kevin Mann",
  "James McDonough",
  "Georgeann W. (Gigi) Redmond",
  "Michael Woltman",
];
---

<Layout title="Board of Governors" description="Officers and Board of Governors of the Cazenovia Club.">

  <!-- ══ HEADER ════════════════════════════════════════════════════ -->
  <div class="relative h-64 overflow-hidden flex items-end">
    <img
      src="/images/govs.jpg"
      alt="Board of Governors"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-[#1B2A4A]/60"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6 pb-10 w-full">
      <p style="font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.2em;" class="text-[#C9A96E] uppercase mb-2">Cazenovia Club</p>
      <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,4vw,3.2rem);font-weight:300;" class="text-white">Officers &amp; Board of Governors</h1>
    </div>
  </div>


  <section class="max-w-4xl mx-auto px-6 py-20 grid grid-cols-1 md:grid-cols-2 gap-16">

    <!-- Officers -->
    <div>
      <p style="font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.2em;" class="text-[#C9A96E] uppercase mb-8">Officers</p>
      <div class="space-y-5">
        {officers.map(o => (
          <div class="flex gap-6 items-baseline border-b border-[#C9A96E]/15 pb-5">
            <span style="font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.12em;min-width:7rem;" class="text-[#C9A96E]/70 uppercase shrink-0">{o.title}</span>
            <span style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:300;" class="text-[#1B2A4A]">{o.name}</span>
          </div>
        ))}
      </div>

      <div class="mt-14">
        <p style="font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.2em;" class="text-[#C9A96E] uppercase mb-6">Club Manager</p>
        <p style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:300;" class="text-[#1B2A4A]">Tina McPherson</p>
      </div>

      <div class="mt-14">
        <p style="font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.2em;" class="text-[#C9A96E] uppercase mb-6">Contact</p>
        <div style="font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:300;line-height:2;" class="text-[#3D3835]/70">
          <p>Cazenovia Club Corporation</p>
          <p>P.O. Box 412</p>
          <p>Cazenovia, NY 13035-0412</p>
          <p class="mt-2"><a href="tel:3156553131" class="hover:text-[#1B2A4A] transition-colors">315.655.3131</a></p>
          <p><a href="mailto:info@cazenoviaclub.org" class="hover:text-[#1B2A4A] transition-colors">info@cazenoviaclub.org</a></p>
        </div>
      </div>
    </div>

    <!-- Governors -->
    <div>
      <p style="font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.2em;" class="text-[#C9A96E] uppercase mb-8">Governors</p>
      <ul class="space-y-4">
        {governors.map(name => (
          <li style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:300;" class="text-[#1B2A4A] border-b border-[#C9A96E]/15 pb-4">
            {name}
          </li>
        ))}
        <li style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:300;" class="text-[#1B2A4A]/50 pb-4 italic">
          Robert S. Constable <span style="font-size:0.9rem;">(emeritus)</span>
        </li>
      </ul>
    </div>

  </section>

</Layout>
